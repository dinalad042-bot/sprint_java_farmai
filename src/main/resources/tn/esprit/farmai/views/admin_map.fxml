<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.farmai.controllers.AdminMapController"
            style="-fx-background-color: #f4f4f4;">

    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #1b5e20; -fx-padding: 12;">
            <Button text="⬅ Retour au Dashboard" onAction="#handleBack"
                    style="-fx-background-color: white; -fx-text-fill: #1b5e20; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"/>
            <Separator orientation="VERTICAL" style="-fx-opacity: 0.3;"/>
            <Label text="FarmAI - Analyse Géographique des Exploitations"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <StackPane>
            <WebView fx:id="mapWebView" />

            <AnchorPane fx:id="paneDetails" visible="false" managed="false" StackPane.alignment="CENTER_RIGHT"
                        maxWidth="320" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">
                <VBox spacing="15" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" style="-fx-padding: 20;">

                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="lblNomFerme" text="Détails de la Ferme"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="✕" onAction="#closeDetails"
                                style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-cursor: hand;"/>
                    </HBox>

                    <Separator />

                    <VBox spacing="8" VBox.vgrow="ALWAYS">
                        <Label text="🐄 Bétail enregistré :" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                        <ListView fx:id="lvAnimaux" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;"/>

                        <Label text="🌱 Cultures en cours :" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                        <ListView fx:id="lvPlantes" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;"/>
                    </VBox>

                    <Button text="Fermer les détails" onAction="#closeDetails" maxWidth="Infinity"
                            style="-fx-background-color: #e8f5e9; -fx-text-fill: #2e7d32; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </VBox>
            </AnchorPane>
        </StackPane>
    </center>
</BorderPane>