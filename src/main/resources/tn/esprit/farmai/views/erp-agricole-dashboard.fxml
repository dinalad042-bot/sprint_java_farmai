<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.farmai.controllers.erp.AgricoleERPController"
            styleClass="dashboard-root"
            stylesheets="@../styles/dashboard.css">

    <left>
        <VBox styleClass="sidebar" prefWidth="270">
            <padding><Insets top="25" right="20" bottom="25" left="20"/></padding>
            <VBox styleClass="sidebar-profile-card" spacing="10" onMouseClicked="#handleProfile" style="-fx-cursor: hand;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane>
                        <Circle fx:id="sidebarAvatar" radius="18" fill="rgba(255,255,255,0.2)" stroke="white"/>
                        <Text fx:id="sidebarAvatarText" text="👨‍🌾" fill="white"/>
                    </StackPane>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Text text="•••" styleClass="menu-dots"/>
                </HBox>
                <VBox spacing="2">
                    <Label fx:id="userNameLabel" text="Agriculteur" styleClass="sidebar-profile-name"/>
                    <Label fx:id="userRoleLabel" text="Production ERP" styleClass="sidebar-profile-role"/>
                </VBox>
            </VBox>
            <Region prefHeight="20"/>
            <VBox spacing="6" styleClass="nav-menu" VBox.vgrow="ALWAYS">
                <Button text="🏠  Mon Tableau de bord" styleClass="nav-button" onAction="#handleBackToDashboard" maxWidth="Infinity"/>
                <Button text="🏭  Production ERP" styleClass="nav-button active" maxWidth="Infinity"/>
                <Button text="🛒  Catalogue Fournisseurs" styleClass="nav-button" onAction="#handleCatalogueMatiere" maxWidth="Infinity"/>
                <Button text="🛍️  Mes Achats" styleClass="nav-button" onAction="#handleAchats" maxWidth="Infinity"/>
                <Button text="📦  Mes Produits Finis" styleClass="nav-button" onAction="#handleProduits" maxWidth="Infinity"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox styleClass="main-content" spacing="20">

                <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="20">
                    <Label text="Espace Production" style="-fx-font-size: 18px; -fx-text-fill: #90A4AE; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="icon-button" onMouseClicked="#handleProfile">
                        <ImageView fx:id="headerProfileImage" fitWidth="36" fitHeight="36" pickOnBounds="true" preserveRatio="true"/>
                    </StackPane>
                </HBox>

                <VBox styleClass="welcome-section" spacing="5">
                    <Label fx:id="welcomeLabel" text="Production ERP" styleClass="welcome-title"/>
                    <Label text="Achetez des matières premières, fabriquez vos produits finis." styleClass="welcome-subtitle"/>
                </VBox>

                <!-- Critical stock alert -->
                <HBox fx:id="alertBox" alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #FFF3E0; -fx-background-radius: 12; -fx-padding: 12 20 12 20;"
                      visible="false" managed="false">
                    <Text text="⚠️" style="-fx-font-size: 18px;"/>
                    <Label fx:id="alertLabel" text="" style="-fx-text-fill: #E65100; -fx-font-weight: bold;" wrapText="true"/>
                </HBox>

                <!-- Stats Row: 3 cards (no ventes for agricole) -->
                <HBox spacing="20">
                    <VBox styleClass="stat-card-tall card-green" HBox.hgrow="ALWAYS" spacing="8">
                        <Label fx:id="totalMatieresLabel" text="0" styleClass="stat-value"/>
                        <Label text="Matières" styleClass="stat-label"/>
                        <Label text="Au catalogue" styleClass="stat-desc"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <ProgressBar progress="0.7" styleClass="progress-bar-modern" maxWidth="Infinity" prefHeight="6"/>
                    </VBox>
                    <VBox styleClass="stat-card-tall card-white" HBox.hgrow="ALWAYS" spacing="8">
                        <Label fx:id="totalAchatsLabel" text="0" styleClass="stat-value"/>
                        <Label text="Achats" styleClass="stat-label"/>
                        <Label text="Effectués" styleClass="stat-desc"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <ProgressBar progress="0.5" styleClass="progress-bar-modern" maxWidth="Infinity" prefHeight="6"/>
                    </VBox>
                    <VBox styleClass="stat-card-tall card-dark" HBox.hgrow="ALWAYS" spacing="8">
                        <Label fx:id="totalProduitsLabel" text="0" styleClass="stat-value"/>
                        <Label text="Produits Finis" styleClass="stat-label"/>
                        <Label text="Fabriqués" styleClass="stat-desc"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <ProgressBar progress="0.4" styleClass="progress-bar-modern" maxWidth="Infinity" prefHeight="6"/>
                    </VBox>
                </HBox>

                <!-- Quick Access: 3 cards matching Symfony agricole dashboard -->
                <HBox spacing="20">
                    <!-- Catalogue Fournisseurs -->
                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS" spacing="12" onMouseClicked="#handleCatalogueMatiere" style="-fx-cursor: hand;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Text text="🛒" style="-fx-font-size: 28px;"/>
                            <VBox>
                                <Label text="Catalogue Fournisseurs" styleClass="card-title"/>
                                <Label text="Parcourir et commander" styleClass="stat-desc"/>
                            </VBox>
                        </HBox>
                        <Label text="Consultez les matières disponibles chez les fournisseurs et passez vos commandes."
                               wrapText="true" styleClass="stat-desc"/>
                        <Button text="🛒  Parcourir le catalogue" styleClass="primary-btn" onAction="#handleCatalogueMatiere" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Mes Achats -->
                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS" spacing="12" onMouseClicked="#handleAchats" style="-fx-cursor: hand;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Text text="🛍️" style="-fx-font-size: 28px;"/>
                            <VBox>
                                <Label text="Mes Achats" styleClass="card-title"/>
                                <Label text="Mes commandes" styleClass="stat-desc"/>
                            </VBox>
                        </HBox>
                        <Label text="Suivez vos bons de commande. Payez les achats en attente pour recevoir les matières."
                               wrapText="true" styleClass="stat-desc"/>
                        <Button text="📋  Voir mes Achats" styleClass="action-btn" onAction="#handleAchats" maxWidth="Infinity"/>
                    </VBox>
                </HBox>

                <HBox spacing="20">
                    <!-- Produits Finis -->
                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS" spacing="12" onMouseClicked="#handleProduits" style="-fx-cursor: hand;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Text text="📦" style="-fx-font-size: 28px;"/>
                            <VBox>
                                <Label text="Produits Finis" styleClass="card-title"/>
                                <Label text="Fabrication" styleClass="stat-desc"/>
                            </VBox>
                        </HBox>
                        <Label text="Créez vos produits, définissez les recettes et lancez la production en consommant vos matières."
                               wrapText="true" styleClass="stat-desc"/>
                        <Button text="⚙️  Gérer les Produits" styleClass="secondary-btn" onAction="#handleProduits" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Info card -->
                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS" spacing="12"
                          style="-fx-background-color: #E8F5E9;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Text text="🌱" style="-fx-font-size: 28px;"/>
                            <Label text="Espace Production" styleClass="card-title"/>
                        </HBox>
                        <Label text="Achetez des matières premières auprès des fournisseurs, fabriquez vos produits finis et gérez tout votre cycle de production ici."
                               wrapText="true" styleClass="stat-desc"/>
                    </VBox>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
