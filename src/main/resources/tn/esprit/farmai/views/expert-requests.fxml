<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.farmai.controllers.ExpertRequestController">

    <!-- Left Sidebar -->
    <left>
        <VBox prefWidth="220" spacing="10" style="-fx-background-color: #2E7D32; -fx-padding: 20;">
            <Text text="🌾 FarmAI" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-fill: white;"/>
            <Label fx:id="userNameLabel" text="Expert" style="-fx-text-fill: white;"/>
            <Label fx:id="userRoleLabel" text="Expert" style="-fx-text-fill: #A5D6A7;"/>

            <VBox spacing="5" style="-fx-padding: 20 0;">
                <Button text="📊 Tableau de bord" onAction="#navigateToDashboard" style="-fx-background-color: #388E3C; -fx-text-fill: white;"/>
                <Button text="📋 Demandes" style="-fx-background-color: #1B5E20; -fx-text-fill: white;"/>
                <Button text="🔬 Analyses" onAction="#navigateToDashboard" style="-fx-background-color: #388E3C; -fx-text-fill: white;"/>
                <Button text="💡 Conseils" onAction="#navigateToDashboard" style="-fx-background-color: #388E3C; -fx-text-fill: white;"/>
                <Button text="🤖 Diagnostic IA" onAction="#handleRefresh" style="-fx-background-color: #9C27B0; -fx-text-fill: white;"/>
            </VBox>

            <Button text="🔄 Actualiser" onAction="#handleRefresh" style="-fx-background-color: #1976D2; -fx-text-fill: white;"/>
            <Button text="🚪 Déconnexion" onAction="#handleLogout" style="-fx-background-color: #C62828; -fx-text-fill: white;"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <ScrollPane style="-fx-background-color: #F5F5F5;">
            <VBox spacing="20" style="-fx-padding: 30;">
                <Text text="📋 Gestion des Demandes" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                <Text text="Gérez les demandes des agriculteurs" style="-fx-font-size: 14px; -fx-fill: #666;"/>

                <!-- Pending Requests -->
                <VBox spacing="10">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Text text="📥 Demandes en attente" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                        <Label fx:id="pendingCountLabel" text="0" style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-padding: 2 8; -fx-background-radius: 10;"/>
                    </HBox>
                    <TableView fx:id="pendingTableView" prefHeight="200">
                        <columns>
                            <TableColumn text="ID" fx:id="colId" prefWidth="50"/>
                            <TableColumn text="Date" fx:id="colDate" prefWidth="120"/>
                            <TableColumn text="Ferme" fx:id="colFerme" prefWidth="80"/>
                            <TableColumn text="Description" fx:id="colDescription" prefWidth="250"/>
                            <TableColumn text="Demandeur" fx:id="colDemandeur" prefWidth="100"/>
                            <TableColumn text="Actions" fx:id="colActions" prefWidth="140"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- My Requests -->
                <VBox spacing="10">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Text text="📋 Mes demandes en cours" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </HBox>
                    <TableView fx:id="myRequestsTableView" prefHeight="200">
                        <columns>
                            <TableColumn text="ID" fx:id="colMyId" prefWidth="50"/>
                            <TableColumn text="Date" fx:id="colMyDate" prefWidth="120"/>
                            <TableColumn text="Ferme" fx:id="colMyFerme" prefWidth="80"/>
                            <TableColumn text="Statut" fx:id="colMyStatut" prefWidth="100"/>
                            <TableColumn text="Résultat" fx:id="colMyResultat" prefWidth="300"/>
                            <TableColumn text="Actions" fx:id="colMyActions" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- Instructions -->
                <VBox spacing="5" style="-fx-background-color: #E3F2FD; -fx-padding: 15; -fx-background-radius: 10;">
                    <Text text="💡 Comment ça marche" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-fill: #1976D2;"/>
                    <Text text="1. Les demandes des agriculteurs apparaissent dans 'Demandes en attente'" style="-fx-fill: #333;"/>
                    <Text text="2. Cliquez 'Prendre en charge' pour vous assigner une demande" style="-fx-fill: #333;"/>
                    <Text text="3. Ajoutez un résultat technique et cliquez 'Terminer' pour finaliser" style="-fx-fill: #333;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>