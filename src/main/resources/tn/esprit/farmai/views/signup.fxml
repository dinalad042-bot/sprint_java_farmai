<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml" 
      fx:controller="tn.esprit.farmai.controllers.SignupController"
      styleClass="login-root"
      stylesheets="@../styles/auth.css">
    
    <!-- Left Panel - Branding -->
    <VBox styleClass="login-left-panel" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="25">
        
        <VBox alignment="CENTER" spacing="15">
            <Label text="🌱" style="-fx-font-size: 64px;"/>
            <Label text="FarmAI" styleClass="app-title-label"/>
            <Label text="Rejoignez-nous" styleClass="app-subtitle-label"/>
        </VBox>
        
        <VBox alignment="CENTER_LEFT" spacing="15" styleClass="feature-list">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="✓" styleClass="feature-check-label"/>
                <Label text="Inscription rapide et sécurisée" styleClass="feature-text-label"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="✓" styleClass="feature-check-label"/>
                <Label text="Accès à tous les outils" styleClass="feature-text-label"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="✓" styleClass="feature-check-label"/>
                <Label text="Support dédié" styleClass="feature-text-label"/>
            </HBox>
        </VBox>
    </VBox>
    
    <!-- Right Panel - Signup Form -->
    <ScrollPane styleClass="signup-scroll" HBox.hgrow="ALWAYS" fitToWidth="true" fitToHeight="true">
        <VBox fx:id="signupContainer" styleClass="login-right-panel" 
              alignment="CENTER" spacing="15">
            
            <VBox styleClass="signup-form-container" spacing="18" alignment="CENTER">
                
                <!-- Header -->
                <VBox alignment="CENTER" spacing="8">
                    <Label text="Créer un compte" styleClass="form-title-label"/>
                    <Label text="Remplissez les informations ci-dessous" styleClass="form-subtitle-label"/>
                </VBox>
                
                <!-- Error Label -->
                <Label fx:id="errorLabel" styleClass="error-label" visible="false" wrapText="true"/>
                
                <!-- Name Fields Row -->
                <HBox spacing="15">
                    <VBox spacing="6" styleClass="input-group" HBox.hgrow="ALWAYS">
                        <Label text="Nom *" styleClass="input-label"/>
                        <TextField fx:id="nomField" 
                                   promptText="Votre nom"
                                   styleClass="auth-input"/>
                    </VBox>
                    <VBox spacing="6" styleClass="input-group" HBox.hgrow="ALWAYS">
                        <Label text="Prénom *" styleClass="input-label"/>
                        <TextField fx:id="prenomField" 
                                   promptText="Votre prénom"
                                   styleClass="auth-input"/>
                    </VBox>
                </HBox>
                
                <!-- Email Field -->
                <VBox spacing="6" styleClass="input-group">
                    <Label text="Email *" styleClass="input-label"/>
                    <TextField fx:id="emailField" 
                               promptText="exemple@email.com"
                               styleClass="auth-input"/>
                </VBox>
                
                <!-- CIN and Phone Row -->
                <HBox spacing="15">
                    <VBox spacing="6" styleClass="input-group" HBox.hgrow="ALWAYS">
                        <Label text="CIN *" styleClass="input-label"/>
                        <TextField fx:id="cinField" 
                                   promptText="8 chiffres"
                                   styleClass="auth-input"/>
                    </VBox>
                    <VBox spacing="6" styleClass="input-group" HBox.hgrow="ALWAYS">
                        <Label text="Téléphone" styleClass="input-label"/>
                        <TextField fx:id="telephoneField" 
                                   promptText="+216 XX XXX XXX"
                                   styleClass="auth-input"/>
                    </VBox>
                </HBox>
                
                <!-- Address Field -->
                <VBox spacing="6" styleClass="input-group">
                    <Label text="Adresse" styleClass="input-label"/>
                    <TextArea fx:id="adresseField" 
                              promptText="Votre adresse complète"
                              styleClass="auth-textarea"
                              prefRowCount="2"/>
                </VBox>
                
                <!-- Password Fields Row -->
                <HBox spacing="15">
                    <VBox spacing="6" styleClass="input-group" HBox.hgrow="ALWAYS">
                        <Label text="Mot de passe *" styleClass="input-label"/>
                        <PasswordField fx:id="passwordField" 
                                       promptText="Min. 6 caractères"
                                       styleClass="auth-input"/>
                    </VBox>
                    <VBox spacing="6" styleClass="input-group" HBox.hgrow="ALWAYS">
                        <Label text="Confirmer *" styleClass="input-label"/>
                        <PasswordField fx:id="confirmPasswordField" 
                                       promptText="Confirmer"
                                       styleClass="auth-input"/>
                    </VBox>
                </HBox>
                
                <!-- Role Selection -->
                <VBox spacing="6" styleClass="input-group">
                    <Label text="Rôle *" styleClass="input-label"/>
                    <ComboBox fx:id="roleComboBox" 
                              styleClass="auth-combo"
                              promptText="Sélectionnez votre rôle"
                              prefWidth="320"/>
                </VBox>
                
                <!-- Terms Checkbox -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <CheckBox fx:id="termsCheckbox" styleClass="terms-checkbox"/>
                    <Label text="J'accepte les conditions d'utilisation" styleClass="form-subtitle-label"/>
                </HBox>
                
                <!-- Loading Indicator -->
                <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="35" prefHeight="35"/>
                
                <!-- Signup Button -->
                <Button fx:id="signupButton" 
                        text="S'inscrire" 
                        styleClass="primary-button"
                        onAction="#handleSignup"
                        prefWidth="320"/>
                
                <!-- Login Link -->
                <HBox alignment="CENTER" spacing="8">
                    <Label text="Déjà inscrit?" styleClass="form-subtitle-label"/>
                    <Hyperlink fx:id="loginLink" 
                               text="Se connecter"
                               styleClass="signup-link"
                               onAction="#handleLoginLink"/>
                </HBox>
                
                <padding>
                    <Insets bottom="30"/>
                </padding>
            </VBox>
        </VBox>
    </ScrollPane>
</HBox>
