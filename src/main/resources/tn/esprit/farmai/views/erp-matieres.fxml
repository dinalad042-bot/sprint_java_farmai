<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Circle?>

<!--
  Matières Premières — FOURNISSEUR only.
  Fournisseur creates/edits/deletes matières (his catalogue).
  Mirrors Symfony erp/matiere/index.html.twig with ROLE_FOURNISSEUR buttons.
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.farmai.controllers.erp.MatieresController"
            styleClass="dashboard-root"
            stylesheets="@../styles/dashboard.css">

    <left>
        <VBox styleClass="sidebar" prefWidth="260">
            <padding><Insets top="25" right="20" bottom="25" left="20"/></padding>
            <VBox styleClass="sidebar-profile-card" spacing="10" onMouseClicked="#handleProfile" style="-fx-cursor: hand;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane>
                        <Circle fx:id="sidebarAvatar" radius="18" fill="rgba(255,255,255,0.2)" stroke="white"/>
                        <Text fx:id="sidebarAvatarText" text="📦" fill="white"/>
                    </StackPane>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Text text="•••" styleClass="menu-dots"/>
                </HBox>
                <VBox spacing="2">
                    <Label fx:id="userNameLabel" text="Fournisseur" styleClass="sidebar-profile-name"/>
                    <Label fx:id="userRoleLabel" text="Mon Catalogue" styleClass="sidebar-profile-role"/>
                </VBox>
            </VBox>
            <Region prefHeight="20"/>
            <VBox spacing="6" styleClass="nav-menu" VBox.vgrow="ALWAYS">
                <Button text="📊  Tableau de bord" styleClass="nav-button" onAction="#handleDashboard" maxWidth="Infinity"/>
                <Button text="🧪  Mon Catalogue" styleClass="nav-button active" maxWidth="Infinity"/>
                <Button text="💰  Mes Ventes" styleClass="nav-button" onAction="#handleVentes" maxWidth="Infinity"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="main-content" spacing="20">

            <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="20">
                <Label text="Mon Catalogue — Matières Premières" style="-fx-font-size: 18px; -fx-text-fill: #90A4AE; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="search-container" alignment="CENTER_LEFT">
                    <Text text="🔍" fill="#9E9E9E"/>
                    <TextField fx:id="searchField" promptText="Rechercher une matière..." styleClass="header-search-field" onKeyReleased="#handleSearch"/>
                </HBox>
                <StackPane styleClass="icon-button" onMouseClicked="#handleProfile">
                    <ImageView fx:id="headerProfileImage" fitWidth="36" fitHeight="36" pickOnBounds="true" preserveRatio="true"/>
                </StackPane>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 0 40 0 40;">
                <Label text="🧪  Mes Matières Premières" styleClass="welcome-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="➕  Nouvelle Matière" styleClass="primary-btn" onAction="#handleAdd"/>
            </HBox>

            <!-- Stats row -->
            <HBox spacing="20" style="-fx-padding: 0 40 0 40;">
                <VBox styleClass="stat-card-tall card-green" HBox.hgrow="ALWAYS" spacing="8">
                    <Label fx:id="totalMatieresLabel" text="0" styleClass="stat-value"/>
                    <Label text="Total Matières" styleClass="stat-label"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <ProgressBar progress="1.0" styleClass="progress-bar-modern" maxWidth="Infinity" prefHeight="6"/>
                </VBox>
                <VBox styleClass="stat-card-tall card-white" HBox.hgrow="ALWAYS" spacing="8">
                    <Label fx:id="critiquesLabel" text="0" styleClass="stat-value"/>
                    <Label text="Stock Critique" styleClass="stat-label"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <ProgressBar progress="0.3" styleClass="progress-bar-modern" maxWidth="Infinity" prefHeight="6"/>
                </VBox>
                <VBox styleClass="stat-card-tall card-dark" HBox.hgrow="ALWAYS" spacing="8">
                    <Label fx:id="valeurLabel" text="0.00 TND" styleClass="stat-value" style="-fx-font-size: 18px;"/>
                    <Label text="Valeur Stock" styleClass="stat-label"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <ProgressBar progress="0.7" styleClass="progress-bar-modern" maxWidth="Infinity" prefHeight="6"/>
                </VBox>
            </HBox>

            <!-- Critical stock alert -->
            <HBox fx:id="alertBox" alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #FFF3E0; -fx-background-radius: 12; -fx-padding: 12 20 12 20;"
                  visible="false" managed="false">
                <Text text="⚠️" style="-fx-font-size: 18px;"/>
                <Label fx:id="alertLabel" text="" style="-fx-text-fill: #E65100; -fx-font-weight: bold;" wrapText="true"/>
            </HBox>

            <!-- Table -->
            <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <TableView fx:id="matieresTable" VBox.vgrow="ALWAYS" style="-fx-pref-height: 450;">
                    <columns>
                        <TableColumn fx:id="colNom" text="Nom" prefWidth="180"/>
                        <TableColumn fx:id="colUnite" text="Unité" prefWidth="70"/>
                        <TableColumn fx:id="colStock" text="Stock" prefWidth="90"/>
                        <TableColumn fx:id="colPrix" text="Prix Unitaire" prefWidth="120"/>
                        <TableColumn fx:id="colSeuil" text="Seuil Critique" prefWidth="110"/>
                        <TableColumn fx:id="colStatut" text="Statut" prefWidth="100"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="170"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucune matière. Cliquez sur '➕ Nouvelle Matière' pour commencer." style="-fx-text-fill: #90A4AE;"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>
