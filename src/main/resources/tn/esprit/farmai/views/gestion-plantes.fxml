<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.farmai.controllers.PlantesController"
            styleClass="dashboard-root" stylesheets="@../styles/dashboard.css">

    <left>
        <VBox styleClass="sidebar" prefWidth="250">
            <padding><Insets top="25" right="20" bottom="25" left="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Text text="🌿" style="-fx-font-size: 20px;"/>
                <Text text="FarmAI" style="-fx-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            </HBox>
            <Region prefHeight="40"/>
            <Button text="⬅ Retour Menu" styleClass="nav-button" onAction="#handleReturnToSelection" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="main-content" spacing="20">
            <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

            <VBox spacing="5">
                <Label text="Gestion des Plantes" styleClass="welcome-title"/>
                <Label text="Suivez le cycle de vie de vos espèces végétales." styleClass="welcome-subtitle"/>
            </VBox>

            <HBox spacing="30" VBox.vgrow="ALWAYS">
                <VBox spacing="15" prefWidth="320" styleClass="content-card">
                    <Label text="Détails de la Plante" styleClass="card-title" style="-fx-font-size: 16px;"/>

                    <VBox spacing="5">
                        <Label text="Nom de l'espèce" style="-fx-font-weight: bold; -fx-text-fill: #546E7A;"/>
                        <TextField fx:id="tfNomEspece" promptText="Ex: Tomate, Maïs" styleClass="search-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Cycle de vie" style="-fx-font-weight: bold; -fx-text-fill: #546E7A;"/>
                        <TextField fx:id="tfCycleVie" promptText="Ex: Semis, Croissance, Récolte" styleClass="search-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Ferme d'affectation" style="-fx-font-weight: bold; -fx-text-fill: #546E7A;"/>
                        <ComboBox fx:id="cbFerme" maxWidth="Infinity" styleClass="filter-combo" promptText="Choisir une ferme"/>
                    </VBox>

                    <Region prefHeight="10"/>

                    <VBox spacing="10">
                        <Button text="Enregistrer" onAction="#ajouter" maxWidth="Infinity" styleClass="primary-btn" style="-fx-background-color: #2E7D32;"/>
                        <HBox spacing="10">
                            <Button text="Modifier" onAction="#modifier" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="secondary-btn"/>
                            <Button text="Supprimer" onAction="#supprimer" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="danger-btn"/>
                        </HBox>
                    </VBox>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS">

                    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="content-card" style="-fx-padding: 10;">
                        <Text text="🔍" style="-fx-font-size: 16px;"/>
                        <TextField fx:id="tfRecherche"
                                   promptText="Rechercher une plante par son nom..."
                                   onKeyReleased="#handleRecherche"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                    </HBox>

                    <TableView fx:id="tvPlantes" VBox.vgrow="ALWAYS" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="colNom" text="Espèce" prefWidth="150"/>
                            <TableColumn fx:id="colCycle" text="Cycle de Vie" prefWidth="150"/>
                            <TableColumn fx:id="colFerme" text="ID Ferme" prefWidth="100"/>
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>