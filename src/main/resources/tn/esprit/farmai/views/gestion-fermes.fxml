<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.farmai.controllers.FermeController"
            styleClass="dashboard-root"
            stylesheets="@../styles/dashboard.css">

    <left>
        <VBox styleClass="sidebar" prefWidth="270" spacing="20">
            <padding><Insets top="25" right="20" bottom="25" left="20"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Text text="🌱" style="-fx-font-size: 24px;"/>
                <Text text="FarmAI" style="-fx-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            </HBox>

            <Region prefHeight="10"/>
            <Button text="⬅ Retour Menu" styleClass="nav-button" onAction="#handleReturnToSelection" maxWidth="Infinity"/>

            <Separator style="-fx-opacity: 0.3;"/>

            <VBox spacing="15" style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 15; -fx-background-radius: 12; -fx-border-color: rgba(76, 175, 80, 0.5);">
                <Label text="🛰️ AUDIT ÉCOSYSTÈME" style="-fx-text-fill: #81C784; -fx-font-weight: bold; -fx-font-size: 12px;"/>

                <VBox spacing="5">
                    <Label text="Score de Synergie :" style="-fx-text-fill: #B0BEC5; -fx-font-size: 11px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblScore" text="--%" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <ProgressBar fx:id="progressSynergy" progress="0.0" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-accent: #4CAF50; -fx-pref-height: 10;"/>
                    </HBox>
                </VBox>

                <VBox spacing="5">
                    <Label text="Autosuffisance Azotée :" style="-fx-text-fill: #B0BEC5; -fx-font-size: 11px;"/>
                    <Label fx:id="lblAzoteRatio" text="0.00 %" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </VBox>

                <ScrollPane prefHeight="100" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <Text fx:id="txtAnalysisResult" text="Sélectionnez une ferme et lancez l'audit pour analyser la synergie via Trefle.io."
                          wrappingWidth="200" style="-fx-fill: #CFD8DC; -fx-font-size: 11px; -fx-font-style: italic;"/>
                </ScrollPane>

                <Button text="Lancer l'Audit IA" onAction="#analyserSynergie" maxWidth="Infinity"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="main-content" spacing="20">
            <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

            <VBox spacing="5">
                <Label text="Gestion des Fermes" styleClass="welcome-title"/>
                <Label text="Combinez vos ressources animales et végétales pour un rendement optimal." styleClass="welcome-subtitle"/>
            </VBox>

            <HBox spacing="30" VBox.vgrow="ALWAYS">

                <VBox spacing="15" prefWidth="320" styleClass="content-card">
                    <Label text="Informations de la ferme" styleClass="card-title" style="-fx-font-size: 16px;"/>

                    <VBox spacing="5">
                        <Label text="Nom de la ferme" style="-fx-font-weight: bold; -fx-text-fill: #546E7A;"/>
                        <TextField fx:id="tfNom" promptText="Ex: Ferme du Nord" styleClass="search-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Localisation (Lieu)" style="-fx-font-weight: bold; -fx-text-fill: #546E7A;"/>
                        <TextField fx:id="tfLieu" promptText="Ex: Bizerte, Tunisie" styleClass="search-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Surface (m²)" style="-fx-font-weight: bold; -fx-text-fill: #546E7A;"/>
                        <TextField fx:id="tfSurface" promptText="Ex: 5000" styleClass="search-field"/>
                    </VBox>

                    <Region prefHeight="10"/>

                    <VBox spacing="10">
                        <Button text="Enregistrer l'unité" onAction="#ajouter" maxWidth="Infinity" styleClass="primary-btn" style="-fx-background-color: #2E7D32;"/>
                        <HBox spacing="10">
                            <Button text="Modifier" onAction="#modifier" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="secondary-btn"/>
                            <Button text="Supprimer" onAction="#supprimer" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="danger-btn"/>
                        </HBox>
                    </VBox>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS">

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="content-card" style="-fx-padding: 10;" HBox.hgrow="ALWAYS">
                            <Text text="🔍" style="-fx-font-size: 16px;"/>
                            <TextField fx:id="tfRecherche"
                                       promptText="Rechercher une exploitation..."
                                       onKeyReleased="#handleRecherche"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                        </HBox>

                        <Button text="📄 PDF"
                                onAction="#imprimerPdf"
                                prefHeight="45"
                                prefWidth="100"
                                style="-fx-background-color: #D32F2F; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>

                    <TableView fx:id="tvFermes" VBox.vgrow="ALWAYS" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="colNom" text="Nom de la Ferme" prefWidth="180"/>
                            <TableColumn fx:id="colLieu" text="Localisation" prefWidth="220"/>
                            <TableColumn fx:id="colSurface" text="Surface (m²)" prefWidth="120"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

            </HBox>
        </VBox>
    </center>
</BorderPane>