<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>
<?import java.net.URL?>

<BorderPane styleClass="dashboard-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.farmai.controllers.FermierAnalysesController">

    <!-- Stylesheets -->
    <stylesheets>
        <URL value="@../styles/dashboard.css" />
        <URL value="@../styles/styles.css" />
    </stylesheets>

    <!-- Sidebar / Topbar ? Pour rester simple, un topbar avec bouton retour -->
    <top>
        <VBox alignment="CENTER" spacing="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Button fx:id="backButton" text="Retour au Tableau de Bord" onAction="#handleBack" styleClass="action-btn" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Mes Analyses (Vue Fermier)" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;" />
            </HBox>
        </VBox>
    </top>

    <!-- Content -->
    <center>
        <VBox spacing="15" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30" left="30" right="30" top="10" />
            </padding>

            <!-- Table View -->
            <TableView fx:id="analysesTableView" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                    <TableColumn fx:id="colDate" text="Date Analyse" prefWidth="150" />
                    <TableColumn fx:id="colResultat" text="Résultat Technique" prefWidth="400" />
                    <TableColumn fx:id="colTechnicien" text="ID Technicien" prefWidth="100" />
                    <TableColumn fx:id="colImage" text="Image" prefWidth="100" />
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="150" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

        </VBox>
    </center>

</BorderPane>
