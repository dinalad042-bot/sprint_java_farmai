<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="tn.esprit.farmai.controllers.AdminDashboardController"
            styleClass="dashboard-root"
            stylesheets="@../styles/dashboard.css">
    
    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="280">
            <padding>
                <Insets top="25" right="20" bottom="25" left="20"/>
            </padding>
            
            <!-- User Profile Card (Top of Sidebar as per template) -->
            <VBox styleClass="sidebar-profile-card" spacing="10" onMouseClicked="#handleProfileEdit" style="-fx-cursor: hand;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane>
                        <ImageView fx:id="profileImageView" fitWidth="40.0" fitHeight="40.0" pickOnBounds="true" preserveRatio="true" />
                    </StackPane>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Text text="•••" styleClass="menu-dots"/>
                </HBox>
                <VBox spacing="2">
                    <Label fx:id="userNameLabel" text="User Name" styleClass="sidebar-profile-name"/>
                    <Label fx:id="userRoleLabel" text="Role" styleClass="sidebar-profile-role"/>
                </VBox>
            </VBox>
            
            <Region prefHeight="30"/>
            
            <!-- Navigation Menu -->
            <VBox spacing="8" styleClass="nav-menu" VBox.vgrow="ALWAYS">
                <Button text="🏠  Tableau de bord" styleClass="nav-button active" maxWidth="Infinity"/>
                <Button text="👥  Utilisateurs" styleClass="nav-button" onAction="#handleManageUsers" maxWidth="Infinity"/>
                <Button text="🌾  Cultures" styleClass="nav-button" maxWidth="Infinity"/>
                <Button text="📦  Produits" styleClass="nav-button" maxWidth="Infinity"/>
                <Button text="🔐  Sécurité" styleClass="nav-button" onAction="#handleProfileEdit" maxWidth="Infinity"/>

                
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>
    
    <!-- Main Content -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox styleClass="main-content" spacing="20">
                
                <!-- Top Header (Search & Actions) -->
                <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="20">
                    <Label text="FarmAI Platform" style="-fx-font-size: 18px; -fx-text-fill: #90A4AE; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <HBox styleClass="search-container" alignment="CENTER_LEFT">
                        <Text text="🔍" fill="#9E9E9E" style="-fx-font-size: 14px;"/>
                        <TextField promptText="Rechercher..." styleClass="header-search-field"/>
                    </HBox>
                    
                    <StackPane styleClass="icon-button" onMouseClicked="#handleProfileEdit">
                        <ImageView fx:id="headerProfileImageView" fitWidth="36.0" fitHeight="36.0" pickOnBounds="true" preserveRatio="true" />
                    </StackPane>
                </HBox>
                
                <!-- Welcome Section -->
                <VBox styleClass="welcome-section" spacing="5">
                    <Label fx:id="welcomeLabel" text="Bonjour, Admin !" styleClass="welcome-title"/>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                         <Label text="Ne remettez jamais à demain ce qui peut être fait aujourd'hui !" styleClass="welcome-subtitle"/>
                         <Text text="🌱" style="-fx-font-size: 16px;"/>
                    </HBox>
                </VBox>
                
                <Label text="Aujourd'hui" styleClass="section-title"/>
                
                <!-- Stats Cards Row (Tall Vertical Cards) -->
                <HBox spacing="20" alignment="CENTER_LEFT">
                    
                    <!-- Card 1: Total Users (Green) -->
                    <VBox styleClass="stat-card-tall, card-green" HBox.hgrow="ALWAYS" spacing="10">
                        <Label fx:id="totalUsersLabel" text="0" styleClass="stat-value"/>
                        <Label text="Total" styleClass="stat-label"/>
                        <Label text="Utilisateurs" styleClass="stat-desc"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <ProgressBar progress="0.75" styleClass="progress-bar-modern" maxWidth="Infinity" prefHeight="8"/>
                        <Label text="Objectif: 100%" styleClass="stat-desc"/>
                    </VBox>
                    
                    <!-- Card 2: Admins (White) -->
                    <VBox styleClass="stat-card-tall, card-white" HBox.hgrow="ALWAYS" spacing="10">
                        <Label fx:id="totalAdminsLabel" text="0" styleClass="stat-value"/>
                        <Label text="Admins" styleClass="stat-label"/>
                        <Label text="Gestionnaires" styleClass="stat-desc"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <ProgressBar progress="0.4" styleClass="progress-bar-modern" maxWidth="Infinity" prefHeight="8"/>
                        <Label text="Actifs" styleClass="stat-desc"/>
                    </VBox>
                    
                    <!-- Card 3: Experts (Grey) -->
                    <VBox styleClass="stat-card-tall, card-grey" HBox.hgrow="ALWAYS" spacing="10">
                        <Label fx:id="totalExpertsLabel" text="0" styleClass="stat-value"/>
                        <Label text="Experts" styleClass="stat-label"/>
                        <Label text="Consultants" styleClass="stat-desc"/>
                        <Region VBox.vgrow="ALWAYS"/>
                         <ProgressBar progress="0.6" styleClass="progress-bar-modern" maxWidth="Infinity" prefHeight="8"/>
                         <Label text="Disponibles" styleClass="stat-desc"/>
                    </VBox>
                    
                    <!-- Card 4: Agricoles (Dark) -->
                    <VBox styleClass="stat-card-tall, card-dark" HBox.hgrow="ALWAYS" spacing="10">
                        <Label fx:id="totalAgricolesLabel" text="0" styleClass="stat-value"/>
                        <Label text="Agricoles" styleClass="stat-label"/>
                        <Label text="Exploitants" styleClass="stat-desc"/>
                        <Region VBox.vgrow="ALWAYS"/>
                         <ProgressBar progress="0.9" styleClass="progress-bar-modern" maxWidth="Infinity" prefHeight="8"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                           <Text text="✔" fill="#4CAF50"/>
                           <Label text="Verifiés" styleClass="stat-desc"/>
                        </HBox>
                    </VBox>
                    
                     <!-- Hidden Card 5 to keep controller happy if mapped (Fournisseur) - using hidden VBox or just add it visible -->
                     <VBox styleClass="stat-card-tall, card-white" HBox.hgrow="ALWAYS" spacing="10">
                         <Label fx:id="totalFournisseursLabel" text="0" styleClass="stat-value"/>
                         <Label text="Fournisseurs" styleClass="stat-label"/>
                         <Label text="Partenaires" styleClass="stat-desc"/>
                         <Region VBox.vgrow="ALWAYS"/>
                         <Text text="📦" style="-fx-font-size: 24px;"/>
                     </VBox>

                </HBox>
                
                <!-- Bottom Section -->
                <HBox spacing="20">
                    <!-- Actions / Quick Access -->
                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS" spacing="15">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Text text="⚡" style="-fx-font-size: 20px;"/>
                            <Label text="Actions Rapides" styleClass="card-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Text text="•••" fill="#B0BEC5"/>
                        </HBox>
                        
                        <HBox spacing="15">
                             <Button text="+ Nouvel Utilisateur" styleClass="primary-btn" onAction="#handleManageUsers"/>
                             <Button text="Voir Statistiques" styleClass="secondary-btn"/>
                        </HBox>
                        
                        <Label text="Dernières Activités" style="-fx-font-weight: bold; -fx-padding: 10px 0 0 0;"/>
                        
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="list-item">
                                <Text text="🆕" styleClass="list-item-icon"/>
                                <VBox>
                                    <Label text="Inscription récente" styleClass="list-item-text"/>
                                    <Label text="Il y a 5 minutes" styleClass="stat-desc"/>
                                </VBox>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="list-item">
                                <Text text="🔄" styleClass="list-item-icon"/>
                                <VBox>
                                    <Label text="Mise à jour système" styleClass="list-item-text"/>
                                    <Label text="Aujourd'hui 09:00" styleClass="stat-desc"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                    
                    <!-- Info / Promo Card -->
                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS" spacing="15" style="-fx-background-color: #E8F5E9;">
                         <HBox alignment="CENTER_LEFT" spacing="10">
                            <Text text="🏢" style="-fx-font-size: 20px;"/>
                            <Label text="FarmAI Enterprise" styleClass="card-title" />
                        </HBox>
                        
                        <Label text="Gérez votre exploitation agricole intelligente avec les dernières technologies d'IA." 
                               wrapText="true" style="-fx-text-fill: #2E7D32; -fx-font-size: 14px;"/>
                               
                        <Region VBox.vgrow="ALWAYS"/>
                        
                        <HBox alignment="CENTER_RIGHT">
                             <Text text="🌱" style="-fx-font-size: 80px; -fx-opacity: 0.2;"/>
                        </HBox>
                    </VBox>
                </HBox>
                
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
