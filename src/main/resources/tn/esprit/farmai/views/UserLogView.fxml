<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="tn.esprit.farmai.controllers.UserLogController"
            styleClass="dashboard-root"
            stylesheets="@../styles/dashboard.css">
    
    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="280">
            <padding>
                <Insets top="25" right="20" bottom="25" left="20"/>
            </padding>
            
            <!-- User Profile Card (Standardized to match admin-dashboard) -->
            <VBox styleClass="sidebar-profile-card" spacing="10" onMouseClicked="#handleProfile" style="-fx-cursor: hand;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane>
                        <Circle fx:id="profileImageView" radius="18" fill="rgba(255,255,255,0.2)" stroke="white"/>
                        <Text fx:id="defaultAvatarText" text="👤" fill="white" visible="false"/>
                    </StackPane>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Text text="•••" styleClass="menu-dots"/>
                </HBox>
                <VBox spacing="2">
                    <Label fx:id="welcomeLabel" text="User" styleClass="sidebar-profile-name"/>
                    <Label fx:id="userRoleLabel" text="Role" styleClass="sidebar-profile-role"/>
                </VBox>
            </VBox>
            
            <Region prefHeight="30"/>
            
            <!-- Navigation Menu (Full Admin Menu - Consistent across all Admin pages) -->
            <VBox spacing="8" styleClass="nav-menu" VBox.vgrow="ALWAYS">
                <Button text="🏠  Tableau de bord" styleClass="nav-button" onAction="#handleDashboard" maxWidth="Infinity"/>
                <Button text="👥  Utilisateurs" styleClass="nav-button" onAction="#handleBack" maxWidth="Infinity"/>
                <Button text="🌾  Cultures" styleClass="nav-button" onAction="#handleCultures" maxWidth="Infinity"/>
                <Button text="📊  Statistiques" styleClass="nav-button" onAction="#handleStatistics" maxWidth="Infinity"/>
                <Button text="📋  Logs Audit" styleClass="nav-button active" maxWidth="Infinity"/>
                <Button text="🔐  Profil" styleClass="nav-button" onAction="#handleProfile" maxWidth="Infinity"/>
                <Button text="📷  Reconnaissance Faciale" styleClass="nav-button" onAction="#handleFaceRecognition" maxWidth="Infinity"/>
                
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>
    
    <!-- Main Content -->
    <center>
        <VBox styleClass="main-content" spacing="20">
            <padding>
                <Insets top="0" right="40" bottom="40" left="40"/>
            </padding>
            
            <!-- Header -->
            <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 20px 0 10px 0;">
                <Label text="Audit des Actions Utilisateurs" style="-fx-font-size: 24px; -fx-text-fill: #263238; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                
                <HBox styleClass="search-container" alignment="CENTER_LEFT">
                    <Text text="🔍" fill="#9E9E9E"/>
                    <TextField promptText="Recherche..." styleClass="header-search-field"/>
                </HBox>
                
                <!-- Notifications -->
                <StackPane style="-fx-cursor: hand;">
                    <padding><Insets top="5" right="5" bottom="5" left="5"/></padding>
                    <Text text="🔔" style="-fx-font-size: 22px;" fill="#546E7A"/>
                    <Label text="0" styleClass="notification-badge" visible="false" StackPane.alignment="TOP_RIGHT"/>
                </StackPane>
                
                <!-- Header User Avatar -->
                <Circle fx:id="headerAvatarImageView" radius="18" fill="#E8F5E9" stroke="#4CAF50"/>
            </HBox>
            
            <!-- Toolbar -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                 <Button text="⬅ Retour" styleClass="secondary-btn" onAction="#handleBack"/>
                 <Region HBox.hgrow="ALWAYS"/>
                 <Button text="🔄 Actualiser" styleClass="secondary-btn" onAction="#handleRefresh"/>
            </HBox>
            
            <!-- List View Card -->
            <VBox styleClass="content-card" VBox.vgrow="ALWAYS" spacing="15">
                <ListView fx:id="logListView" VBox.vgrow="ALWAYS" styleClass="user-list-view">
                    <placeholder>
                        <Label text="Aucun log d'audit trouvé" styleClass="table-placeholder"/>
                    </placeholder>
                </ListView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
