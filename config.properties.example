# FarmAI Configuration
# Copy this file to config.properties and fill in your values

# ========================================
# AI Services Configuration
# ========================================

# Groq API Configuration (US8: AI-Assisted Diagnostics)
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ========================================
# Weather API Configuration
# ========================================

# Weather API uses Open-Meteo (FREE - No API key required!)
# The WeatherUtils class automatically uses Open-Meteo API
# No configuration needed - works out of the box
# Reference: https://open-meteo.com/

# ========================================
# Text-to-Speech Configuration  
# ========================================

# TTS uses system speech synthesis (FREE - No API key required!)
# Windows: Uses SAPI (Speech API) via PowerShell
# macOS: Uses 'say' command with French voice
# Linux: Uses 'espeak' if available
# The SpeechUtils class handles this automatically

# Optional: Voice RSS API for online TTS fallback
# Get your free API key from: https://www.voicerss.org/
# VOICE_RSS_API_KEY=your_voice_rss_api_key_here

# ========================================
# Application Settings
# ========================================

# PDF Generation Settings
PDF_AUTHOR=FarmAI System
PDF_CREATOR=FarmAI Technical Reporting Module
PDF_OUTPUT_DIR=/tmp/farmai_reports/

# Chart Settings (US10)
CHART_TITLE=FarmAI Analytics Dashboard
