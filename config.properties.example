# ============================================
# FarmAI Configuration File
# ============================================
# Copy this file and fill in your credentials
# This file should NOT be committed to version control
# if it contains real API keys!

# ============================================
# Groq API Configuration (AI Chatbot)
# ============================================
# Get your API key from: https://console.groq.com/keys
# Used for: Expert AI assistant, irrigation recommendations
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# Trefle API Configuration (Plant Database)
# ============================================
# Get your API key from: https://trefle.io/
# Used for: Plant species search, ecosystem audit
# A default public key is provided as fallback
TREFLE_API_KEY=your_trefle_api_key_here

# ============================================
# Email/SMTP Configuration (Notifications)
# ============================================
# For Gmail, you need an "App Password" (not your regular password)
# Create one at: https://myaccount.google.com/apppasswords
# Used for: Password reset, OTP verification, notifications

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# ============================================
# Database Configuration (Optional Override)
# ============================================
# Default values are in MyDBConnexion.java
# Only override if you need different settings

# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=farmai
# DB_USER=root
# DB_PASSWORD=

# ============================================
# Weather API Configuration (Optional)
# ============================================
# Get your API key from: https://openweathermap.org/api
# Used for: Irrigation AI recommendations

# WEATHER_API_KEY=your_openweather_api_key_here